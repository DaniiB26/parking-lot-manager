<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.2" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ui.ParkingLotController">
    <top>
        <VBox spacing="8.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="12.0" right="12.0" bottom="6.0" left="12.0"/>
            </padding>
            <Label text="Parking Lot Manager"/>
            <GridPane hgap="8.0" vgap="8.0">
                <Label text="License plate" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="licensePlateField" promptText="B 123 ABC"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Ticket ID" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="ticketIdField" promptText="1"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Exit time (optional)" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="exitTimeField" promptText="24.04.2026 14:30"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            </GridPane>
            <HBox spacing="8.0">
                <Button text="Enter Parking" onAction="#onEnterParking"/>
                <Button text="Calculate Price" onAction="#onCalculatePrice"/>
                <Button text="Pay Ticket" onAction="#onPayTicket"/>
                <Button text="Close Ticket" onAction="#onCloseTicket"/>
                <Button text="Refresh" onAction="#onRefreshTickets"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <ListView fx:id="ticketsListView" BorderPane.alignment="CENTER"/>
    </center>
    <bottom>
        <Label fx:id="resultLabel" text="Ready">
            <padding>
                <Insets top="6.0" right="12.0" bottom="12.0" left="12.0"/>
            </padding>
        </Label>
    </bottom>
</BorderPane>
